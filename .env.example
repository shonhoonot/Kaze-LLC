# ─────────────────────────────────────────────────────────────
# Kaze Shop — example environment configuration
# Copy to `.env` and fill in. NEVER commit the real .env.
# ─────────────────────────────────────────────────────────────

# --- Database ---
POSTGRES_USER=kaze
POSTGRES_PASSWORD=kaze_dev_password
POSTGRES_DB=kaze
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://kaze:kaze_dev_password@db:5432/kaze

# --- Auth / JWT ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- OTP ---
# In dev, OTP codes are returned in the API response and logged.
# In prod, wire an SMS provider here.
OTP_DEV_MODE=true
SMS_PROVIDER=stub

# --- Pricing engine defaults (admin-editable at runtime) ---
DEFAULT_MARKUP_PERCENT=0.10
DEFAULT_SERVICE_FEE_PER_ITEM_JPY=400
DEFAULT_SHIPPING_FEE_PER_KG_JPY=350
DEFAULT_FX_RATE_JPY_MNT=22.5
DEFAULT_FX_MODE=manual

# --- FX live mode (optional) ---
FX_LIVE_API_URL=
FX_LIVE_API_KEY=

# --- Shipping estimate (ачаа явах огнооны таамаг) ---
BOX_FILL_GRAMS_PER_DAY=1500
JP_HANDLING_DAYS=5
SEA_TRANSIT_DAYS=21

# --- Payments (QPay) ---
QPAY_BASE_URL=https://merchant.qpay.mn/v2
QPAY_USERNAME=
QPAY_PASSWORD=
QPAY_INVOICE_CODE=
QPAY_CALLBACK_URL=http://localhost:8000/payments/qpay/callback
PAYMENT_PROVIDER=stub

# --- Object storage ---
# storage_backend: local | azure_blob
STORAGE_BACKEND=local
UPLOAD_DIR=/app/uploads
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=product-images

# --- App ---
CORS_ORIGINS=http://localhost:3000
ENV=development

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
